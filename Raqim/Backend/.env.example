# OCR engine: deepseek (local GPU) or kawn (cloud API, no GPU)
OCR_PROVIDER=deepseek

# Kawn Baseer OCR (required when OCR_PROVIDER=kawn)
KAWN_API_KEY=your_kawn_api_key_here
KAWN_API_BASE_URL=https://api.kawn.ai
KAWN_OCR_MODEL=baseer/baseer-v2
KAWN_POLL_INTERVAL_SECONDS=2
KAWN_POLL_TIMEOUT_SECONDS=600

# LLM suggestions via Groq / ALLaM
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
GROQ_MODEL=allam-2-7b
ALLAM_SUGGESTIONS_ENABLED=true
