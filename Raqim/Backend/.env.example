GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
GROQ_MODEL=allam-2-7b
ALLAM_SUGGESTIONS_ENABLED=true

# OCR engine selection:
#   OCR_ENGINE=deepseek  -> DeepSeek-OCR-2 (default; uses requirements.txt deps)
#   OCR_ENGINE=dots      -> DotOCR / dots.mocr layout engine
#   OCR_ENGINE=fusion    -> DeepSeek text + DotOCR layout fusion (experimental).
#                           DeepSeek stays the source of truth for text; DotOCR
#                           only adds structure (headings/tables/pictures). If
#                           DotOCR fails, the DeepSeek-only result is returned.
# NOTE: deepseek and dots need different transformers versions and cannot be
# installed at the same time:
#   * deepseek -> transformers==4.46.3 (requirements.txt)
#   * dots     -> transformers==4.57.6 (requirements-dots.txt)
# The fusion mode runs BOTH engines, so it requires an environment where both
# DeepSeek and dots.mocr can load. Where that is not possible, fusion still runs
# DeepSeek and simply skips the DotOCR layout pass (graceful degradation).
# Install the deps that match the engine you select.
OCR_ENGINE=deepseek

# DotOCR (dots.mocr) settings (only used when OCR_ENGINE=dots):
DOTS_MOCR_MODEL_NAME=rednote-hilab/dots.mocr
DOTS_MAX_NEW_TOKENS=8192
# DOTS_DEVICE=cuda   # auto-detected (cuda if available, else cpu) when unset
