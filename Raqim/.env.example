# Copy this file to `.env` next to docker-compose.yml and fill in your values.
# docker-compose automatically loads variables from a `.env` file in this folder.

# --- ALLaM via Groq (required for ALLaM suggestions) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=allam-2-7b
LLM_PROVIDER=groq

# --- OCR ---
OCR_TESSERACT_LANG=ara+eng

# --- Optional: CorpusFilter service ---
# When you enable the "corpusfilter" profile, point the backend at it.
# Default (inside the compose network): http://corpusfilter:9090/correct
CORPUS_FILTER_API_URL=http://corpusfilter:9090/correct
# Image to use for the optional corpusfilter service:
# CORPUSFILTER_IMAGE=your-org/corpusfilter:latest

# --- Optional: override the backend URL baked into the React build ---
# REACT_APP_API_BASE_URL=http://localhost:5000
